# Runtime
NODE_ENV=production
PORT=3000
APP_BASE_URL=https://your-render-service.onrender.com
LOG_LEVEL=info

# Business deployment identity
BUSINESS_ID=your-business-uuid

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_VERIFY_TOKEN=choose-a-random-verify-token
WHATSAPP_GRAPH_VERSION=v22.0

# OpenRouter
OPENROUTER_API_KEY=sk-or-xxxxxxxx
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_MAX_TOKENS=600
OPENROUTER_TEMPERATURE=0.35

# Hugging Face embeddings
HF_API_TOKEN=hf_xxxxxxxxxxxxx
HF_EMBEDDING_MODEL=BAAI/bge-m3

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Retrieval + conversation
MAX_HISTORY_MESSAGES=10
VECTOR_TOP_K=10
VECTOR_SIMILARITY_THRESHOLD=0.65
MAX_CANDIDATE_IMAGES=3
